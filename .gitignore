# Rust build output
target/
**/*.rs.bk

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# Python tooling caches generated by release/model helper scripts
__pycache__/
*.py[cod]

# Machine-local Claude Code integration. UmaDev writes the current executable
# path here using Claude's non-shareable project settings surface.
.claude/settings.local.json

# Workspace runtime state (per-project, not source) — all of .umadev/ is
# generated/user data: workflow state, audit, checkpoints shadow-git, KB index.
.umadev/
# Legacy runtime-state dir from the pre-rename name — never commit
.super-dev/
.umadev/knowledge-stats.db
.umadev/install-manifest.json
.umadev/project.md
.umadev/runs/
.umadev/coach/
.umadev/changes/
.umadev/history/
.umadev/input-history.txt
.umadev/kb-index/
# `.umadev` written anywhere (e.g. running `umadev` inside a crate dir)
**/.umadev/
# Per-workspace spec manifest, auto-written by `umadev init`
umadev.yaml
# Locally generated demo/example projects
examples/

# Per-platform npm sub-packages have their binaries populated at
# release time; .gitkeep keeps the dir tracked but the actual binaries
# never live in source control.
npm/cli-*/bin/umadev
npm/cli-*/bin/umadev.exe

# Generated artifacts the user keeps locally
output/

# Node modules from the marketing site
umadev-website/node_modules/
umadev-website/.next/
umadev-website/out/

# Secrets
.env
.env.local
.env.*.local
*.pem
*.key

# AI coding-tool config files — internal, not for public display (kept locally)
CLAUDE.md
AGENTS.md
.claude/CLAUDE.md

# Internal development-process docs — kept locally, not published
/docs/AGENT_WIELDS_BASE_ARCHITECTURE.md
/docs/CONTINUOUS_SESSION_ARCHITECTURE.md
/docs/SELF_LEARNING_PITFALL_KB.md
/docs/TOP_TIER_DESIGN.md
/docs/UX_MATURITY_ROADMAP.md
/docs/DEV_TEAM_AGENT_VISION.md
/docs/plans/
# Untracked dev scratch (never publish)
/UMADEV.md
/super_dev/
/.playwright-mcp/
